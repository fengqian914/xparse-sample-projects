# TextIn Document Parsing API credentials
# Get these from https://www.textin.com → Developer Center
TEXTIN_APP_ID=your_app_id_here
TEXTIN_SECRET_CODE=your_secret_code_here

# ─── LLM provider ─────────────────────────────────────────────────────────────
# Two options are supported. Configure ONE of them.
#
# Option A: Internal AI Gateway (e.g. WPS ai-gateway)
#   When AI_GATEWAY_URL is set, the backend will route LLM calls to the gateway
#   using the gateway protocol (custom headers + base_llm_arguments payload).
#
# Option B: OpenAI-compatible API (Aliyun DashScope, OpenAI, DeepSeek, vLLM, …)
#   Used as a fallback when AI_GATEWAY_URL is empty.

# ── Option A: AI Gateway ──
AI_GATEWAY_URL=http://ai-gateway.wps.cn/test/api/v2/llm/chat
AI_GATEWAY_TOKEN=your_gateway_token_here
AI_GATEWAY_UID=your_uid_here
AI_GATEWAY_PRODUCT=saas_knowledgebase_web
AI_GATEWAY_INTENTION=dc_saas_knowledgebase_extract
AI_GATEWAY_PROVIDER=ali
AI_GATEWAY_MODEL=qwen-plus
AI_GATEWAY_MAX_TOKENS=8192

# ── Option B: OpenAI-compatible API ──
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen-plus